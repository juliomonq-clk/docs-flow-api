meta {
  name: Atualizar flow (draft ou unpublished)
  type: http
  seq: 4
}

put {
  url: {{sequencer_base_url}}/flows/{{flow_id}}
  body: json
  auth: inherit
}

body:json {
  {
    "name": "Onboarding de colaborador — revisado",
    "steps": []
  }
}

docs {
  Retorna 403 se o flow estiver published. Despublique antes com "Despublicar flow" para voltar a editar.
}
