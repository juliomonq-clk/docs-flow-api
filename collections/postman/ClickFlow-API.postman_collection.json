{
  "info": {
    "name": "ClickFlow API",
    "description": "Sequencer (Orquestrador) + Runner (Executor) do ClickFlow. Veja docs/05-guia-de-integracao.md no repositório para o passo a passo completo.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "Authorization", "type": "string" },
      { "key": "value", "value": "{{access_token}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Sequencer — Flows",
      "item": [
        {
          "name": "Listar flows",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{sequencer_base_url}}/flows", "host": ["{{sequencer_base_url}}"], "path": ["flows"] }
          }
        },
        {
          "name": "Criar flow",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Onboarding de colaborador\",\n  \"steps\": [\n    { \"type\": \"form\", \"context\": { \"version_key\": \"<version_key do formulário>\" } },\n    { \"type\": \"verify\", \"context\": { \"authentication\": \"liveness\" } },\n    { \"type\": \"signature\", \"context\": { \"documents\": [ { \"kind\": \"template\", \"template_key\": \"<uuid do modelo Távola>\", \"filename\": \"contrato.docx\" } ], \"settings\": { \"folder_key\": \"<referência da pasta>\" } } }\n  ]\n}"
            },
            "url": { "raw": "{{sequencer_base_url}}/flows", "host": ["{{sequencer_base_url}}"], "path": ["flows"] }
          }
        },
        {
          "name": "Obter flow por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{sequencer_base_url}}/flows/{{flow_id}}", "host": ["{{sequencer_base_url}}"], "path": ["flows", "{{flow_id}}"] }
          }
        },
        {
          "name": "Atualizar flow (draft ou unpublished)",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Onboarding de colaborador — revisado\",\n  \"steps\": []\n}"
            },
            "url": { "raw": "{{sequencer_base_url}}/flows/{{flow_id}}", "host": ["{{sequencer_base_url}}"], "path": ["flows", "{{flow_id}}"] },
            "description": "Retorna 403 se o flow estiver published — despublique antes (\"Despublicar flow\")."
          }
        },
        {
          "name": "Publicar flow",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": { "raw": "{{sequencer_base_url}}/flows/{{flow_id}}/publish", "host": ["{{sequencer_base_url}}"], "path": ["flows", "{{flow_id}}", "publish"] },
            "description": "draft ou unpublished → published."
          }
        },
        {
          "name": "Despublicar flow",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": { "raw": "{{sequencer_base_url}}/flows/{{flow_id}}/unpublish", "host": ["{{sequencer_base_url}}"], "path": ["flows", "{{flow_id}}", "unpublish"] },
            "description": "published → unpublished. Permite voltar a editar o flow. Não afeta execuções em andamento."
          }
        },
        {
          "name": "Remover flow",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{sequencer_base_url}}/flows/{{flow_id}}", "host": ["{{sequencer_base_url}}"], "path": ["flows", "{{flow_id}}"] },
            "description": "Soft delete — status passa a \"deleted\". Retorna 204 No Content."
          }
        }
      ]
    },
    {
      "name": "Sequencer — Executions",
      "item": [
        {
          "name": "Listar execuções de um flow",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{sequencer_base_url}}/flows/{{flow_id}}/executions", "host": ["{{sequencer_base_url}}"], "path": ["flows", "{{flow_id}}", "executions"] }
          }
        },
        {
          "name": "Estado consolidado da execução",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{sequencer_base_url}}/executions/{{execution_id}}", "host": ["{{sequencer_base_url}}"], "path": ["executions", "{{execution_id}}"] }
          }
        },
        {
          "name": "Avançar para o próximo step",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{sequencer_base_url}}/executions/{{execution_id}}/next", "host": ["{{sequencer_base_url}}"], "path": ["executions", "{{execution_id}}", "next"] }
          }
        }
      ]
    },
    {
      "name": "Runner — Executions",
      "item": [
        {
          "name": "Iniciar execução (execute)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contact\": {\n    \"person_name\": \"Maria Silva\",\n    \"person_documentation\": \"00000000000\",\n    \"person_birthday\": \"1990-01-01\",\n    \"phone_number\": \"+5511999999999\"\n  }\n}"
            },
            "url": { "raw": "{{runner_base_url}}/flows/{{flow_id}}/execute", "host": ["{{runner_base_url}}"], "path": ["flows", "{{flow_id}}", "execute"] },
            "description": "Canal padrão (channel omitido = \"whatsapp\"). Para o modo headless, veja \"Iniciar execução (canal api)\"."
          }
        },
        {
          "name": "Iniciar execução (canal api)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"channel\": \"api\",\n  \"contact\": {\n    \"person_name\": \"Maria Silva\",\n    \"person_documentation\": \"00000000000\",\n    \"person_birthday\": \"1990-01-01\",\n    \"phone_number\": \"+5511999999999\"\n  }\n}"
            },
            "url": { "raw": "{{runner_base_url}}/flows/{{flow_id}}/execute", "host": ["{{runner_base_url}}"], "path": ["flows", "{{flow_id}}", "execute"] },
            "description": "Modo headless — Runner não envia mensagens automáticas via WhatsApp (exceto steps acceptance). Resposta traz current_step.url. Ver docs/04-canais.md."
          }
        },
        {
          "name": "HEAD da execução",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{runner_base_url}}/executions/{{execution_id}}", "host": ["{{runner_base_url}}"], "path": ["executions", "{{execution_id}}"] }
          }
        },
        {
          "name": "Histórico de steps da execução",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{runner_base_url}}/executions/{{execution_id}}/steps", "host": ["{{runner_base_url}}"], "path": ["executions", "{{execution_id}}", "steps"] }
          }
        }
      ]
    },
    {
      "name": "Runner — Webhooks",
      "item": [
        {
          "name": "Webhook de assinatura (Tavola)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Content-Hmac", "value": "SHA256=<hex>" }
            ],
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": {\n    \"name\": \"sign\",\n    \"data\": {\n      \"signer\": {\n        \"key\": \"<signer_key>\",\n        \"phone_number\": \"+5511999999999\"\n      }\n    }\n  },\n  \"document\": {\n    \"key\": \"<document_key>\"\n  }\n}"
            },
            "url": { "raw": "{{runner_base_url}}/webhooks/signature", "host": ["{{runner_base_url}}"], "path": ["webhooks", "signature"] },
            "description": "Endpoint inbound chamado pelo Tavola — mantido aqui como referência do payload, não faz parte do fluxo normal de uma empresa integradora. Sempre responde 200 (processed/ignored); 401 indica HMAC inválido."
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Sequencer — Health",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{sequencer_base_url}}/health", "host": ["{{sequencer_base_url}}"], "path": ["health"] }
          }
        },
        {
          "name": "Runner — Health",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{runner_base_url}}/health", "host": ["{{runner_base_url}}"], "path": ["health"] }
          }
        }
      ]
    }
  ]
}
