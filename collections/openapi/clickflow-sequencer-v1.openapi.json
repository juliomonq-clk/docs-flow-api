{
  "openapi": "3.0.3",
  "info": {
    "title": "ClickFlow Orchestrator API",
    "version": "1.0",
    "description": "### Visão geral\n\nO ClickFlow Orchestrator é o serviço central responsável pelo estado e pela sequência linear de jornadas transacionais, composta por módulos desacoplados: WhatsApp, Formulários, Verificação, KYC e Assinatura.\n\n### Persistência e responsabilidades\n\nA orquestração é exposta como serviço stateless; o estado autoritativo fica em Amazon DynamoDB. A API separa claramente duas frentes de operação:\n\n- Flows — definição estrutural da jornada: ordem dos steps e o contexto associado a cada etapa.\n- Executions — instâncias em execução: criação, transição entre steps e rastreamento do progresso em tempo real.\n\n### Autenticação e Segurança\n\nTodos os recursos da rota `/api/v1` exigem autenticação. Envie o cabeçalho `Authorization` contendo exclusivamente o UUID do token (sem prefixo `Bearer`).\n\nOs recursos da rota `/api/internal` são exclusivos para uso interno do frontend Tavola — autenticação via `Authorization: Bearer <jwt>` (RS512) com sessão em Redis. Não fazem parte do contrato público e não estão documentados aqui.\n\n---\nSpec extraído do endpoint de documentação viva do serviço (`/api/v1/docs/doc.json`) em 13/07/2026 (revisão anterior: 07/07/2026). `servers` abaixo foram adicionados por este repositório — não fazem parte do spec original.",
    "contact": { "name": "Clicksign — ClickFlow" }
  },
  "servers": [
    { "url": "https://clickflow-sandbox.clicksign.com/api/v1", "description": "Sandbox — use este ambiente para testes" },
    { "url": "https://clickflow.clicksign.com/api/v1", "description": "Produção" }
  ],
  "security": [{ "ApiKeyAuth": [] }],
  "tags": [
    { "name": "flows" },
    { "name": "executions" },
    { "name": "health" }
  ],
  "paths": {
    "/flows": {
      "get": {
        "tags": ["flows"],
        "summary": "Lista flows",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/domain.Flow" } } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorUnauthorizedResponse" } } } },
          "503": { "description": "Service Unavailable", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } }
        }
      },
      "post": {
        "tags": ["flows"],
        "summary": "Cria flow (draft)",
        "description": "account e user_id vêm do token (Authorization), via introspecção em AUTH_URL — não do body. Validação estrutural do context `acceptance` (template_key, accept_replies) no orquestrador; match da resposta do usuário no runner. Validação do contexto do passo `signature` ocorre no executor (runner).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/handler.CreateFlowBody" },
              "examples": {
                "acceptance": { "summary": "Acceptance", "value": { "name": "Proposta Crédito — acceptance", "steps": [ { "type": "acceptance", "context": { "template_key": "chave-do-template", "accept_replies": ["accept", "aceitar"] } } ] } },
                "form": { "summary": "Form", "value": { "name": "Proposta Crédito — form", "steps": [ { "type": "form", "context": { "version_key": "sua-form-version-key" } } ] } },
                "form_contact": { "summary": "Form — atualização de contato", "value": { "name": "Proposta Crédito — form com atualização de contato", "steps": [ { "type": "form", "context": { "version_key": "a0cfcec8-4d18-49a8-b6d1-85df293d5cb4", "contact": { "person_name": "...", "person_documentation": "...", "person_birthday": "...", "phone_number": "..." } } } ] } },
                "form_forward_fill": { "summary": "Form — injeção de respostas de formulários anteriores", "value": { "name": "Injeção de respostas de formulários anteriores", "steps": [ { "type": "form", "context": { "version_key": "versao-formulario-cadastro" } }, { "type": "form", "context": { "version_key": "versao-formulario-confirmacao", "context_map_keys": { "nome-completo-confirmacao": { "read_only": false, "value": "nome-completo-cadastro" }, "email-confirmacao": { "read_only": true, "value": "email-cadastro" }, "whatsapp-confirmacao": { "read_only": true, "value": "whatsapp-cadastro" }, "campo-destino-formulario-atual": { "read_only": false, "value": "campo-origem" } } } } ] } },
                "form_forward_fill_contact": { "summary": "Form — injeção do contato no formulário", "value": { "name": "Injeção do contato no formulário", "steps": [ { "type": "form", "context": { "version_key": "versao-formulario-confirmacao", "context_map_keys": { "nome-completo": { "read_only": true, "value": "{{person_name}}" }, "cpf": { "read_only": true, "value": "{{person_documentation}}" }, "data-nascimento": { "read_only": true, "value": "{{person_birthday}}" }, "whatsapp": { "read_only": true, "value": "{{phone_number}}" } } } } ] } },
                "verify": { "summary": "Verify — liveness", "value": { "name": "Proposta Crédito — verify", "steps": [ { "type": "verify", "context": { "authentication": "liveness" } } ] } },
                "verify_biometric_behavior": { "summary": "Verify — biometric_behavior", "value": { "name": "Proposta Crédito — verify biometric_behavior", "steps": [ { "type": "verify", "context": { "authentication": "biometric_behavior" } } ] } },
                "verify_biometric_behavior_with_form": { "summary": "Verify — biometric_behavior + form", "value": { "name": "Proposta Crédito — verify biometric_behavior + form", "steps": [ { "type": "form", "context": { "version_key": "sua-form-version-key" } }, { "type": "verify", "context": { "authentication": "biometric_behavior", "contact_fields_map": { "person_name": "field-key-do-nome", "person_documentation": "field-key-do-documento" } } } ] } },
                "kyc_biometric_behavior": { "summary": "KYC — biometric_behavior + kyc (CNPJ)", "value": { "name": "Proposta Crédito — verify biometric_behavior + kyc (CNPJ)", "steps": [ { "type": "verify", "context": { "authentication": "biometric_behavior" } }, { "type": "kyc", "context": { "type": "business" } } ] } },
                "kyc_form_biometric_behavior": { "summary": "KYC — form + biometric_behavior + kyc (CPF)", "value": { "name": "Proposta Crédito — form + verify biometric_behavior + kyc (CPF)", "steps": [ { "type": "form", "context": { "version_key": "sua-form-version-key" } }, { "type": "verify", "context": { "authentication": "biometric_behavior", "contact_fields_map": { "person_name": "field-key-do-nome", "person_documentation": "field-key-do-documento" } } }, { "type": "kyc", "context": { "type": "customer" } } ] } },
                "signature_file": { "summary": "Signature — arquivo S3", "value": { "name": "Proposta Crédito", "steps": [ { "type": "signature", "context": { "documents": [ { "kind": "file", "s3_bucket": "meu-bucket", "s3_key": "caminho/para/contrato.pdf", "filename": "contrato-proposta.pdf" } ], "settings": { "folder_key": "1fb29ab8-84c4-4856-be37-5fce0f17c11a" } } } ] } },
                "signature_template": { "summary": "Signature — modelo Távola", "value": { "name": "Proposta Crédito — template", "steps": [ { "type": "signature", "context": { "documents": [ { "kind": "template", "template_key": "uuid-do-modelo-tavola", "filename": "contrato-proposta.docx" } ], "settings": { "folder_key": "1fb29ab8-84c4-4856-be37-5fce0f17c11a" } } } ] } },
                "signature_mixed": { "summary": "Signature — arquivo S3 + modelo Távola", "value": { "name": "Proposta Crédito — arquivo S3 + template", "steps": [ { "type": "signature", "context": { "documents": [ { "kind": "file", "s3_bucket": "meu-bucket", "s3_key": "caminho/para/anexo.pdf", "filename": "anexo.pdf" }, { "kind": "template", "template_key": "uuid-do-modelo-tavola", "filename": "contrato.docx" } ], "settings": { "folder_key": "1fb29ab8-84c4-4856-be37-5fce0f17c11a" } } } ] } },
                "signature_filename_interpolado": { "summary": "Signature — filename com interpolação", "value": { "name": "Proposta Crédito — form + signature com filename", "steps": [ { "type": "form", "context": { "version_key": "sua-form-version-key" } }, { "type": "signature", "context": { "documents": [ { "kind": "template", "template_key": "uuid-do-modelo-tavola", "filename": "doc_{{person_name}}_{{field-key-do-version}}.docx" } ], "settings": { "folder_key": "1fb29ab8-84c4-4856-be37-5fce0f17c11a" } } } ] } },
                "signature_signers_extras": { "summary": "Signature — template + signatários extras (novo, 16/07/2026)", "value": { "name": "Proposta Crédito — assinatura com signatários extras", "steps": [ { "type": "signature", "context": { "documents": [ { "filename": "{{person_name}}.docx", "kind": "template", "template_key": "uuid-do-modelo-tavola" } ], "settings": { "folder_key": "1fb29ab8-84c4-4856-be37-5fce0f17c11a" }, "signers": [ { "auths": ["handwritten"], "birthday": "2021-07-15", "communicate_events": { "document_signed": "email", "signature_reminder": "email", "signature_request": "email" }, "documentation": "34623794024", "email": "signatario.fixo@mail.com", "group": 1, "has_documentation": true, "location_required_enabled": true, "name": "Signatário Fixo", "phone_number": "49999999999", "refusable": false, "roles": ["witness"] }, { "auths": ["liveness", "whatsapp"], "birthday": "{{person_birthday}}", "documentation": "{{person_documentation}}", "group": 2, "name": "{{person_name}}", "phone_number": "{{phone_number}}", "roles": ["sign"] } ] } } ] } },
                "signature_envelope_settings": { "summary": "Signature — template + configurações do envelope (novo, 22/07/2026)", "value": { "name": "Proposta Crédito — assinatura com configurações do envelope", "steps": [ { "type": "signature", "context": { "documents": [ { "filename": "{{person_name}}_settings.docx", "kind": "template", "template_key": "uuid-do-modelo-tavola" } ], "settings": { "auto_close": false, "block_after_refusal": false, "deadline_at": "2026-07-30T15:30:00Z", "default_message": "Envelope com configurações extras", "default_subject": "Aplicação de parâmetros extras no envelope", "folder_key": "1fb29ab8-84c4-4856-be37-5fce0f17c11a", "locale": "en-US", "remind_interval": "2" } } } ] } }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/domain.Flow" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorUnauthorizedResponse" } } } },
          "503": { "description": "Service Unavailable", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } }
        }
      }
    },
    "/flows/{id}": {
      "parameters": [ { "name": "id", "in": "path", "required": true, "description": "Flow ID", "schema": { "type": "string" } } ],
      "get": {
        "tags": ["flows"],
        "summary": "Obtém flow por ID",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/domain.Flow" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorUnauthorizedResponse" } } } },
          "404": { "description": "Not Found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } }
        }
      },
      "put": {
        "tags": ["flows"],
        "summary": "Atualiza flow",
        "description": "Envia tipicamente name e steps. account e user_id são preservados do recurso persistido (ignorados no body). Retorna 403 se o flow estiver `published` — despublique antes via PATCH /flows/{id}/unpublish para voltar a editar (ver domain.FlowStatus).",
        "requestBody": {
          "required": true,
          "description": "Campos (ex.: name, steps)",
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/domain.Flow" } } }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/domain.Flow" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorUnauthorizedResponse" } } } },
          "403": { "description": "Forbidden — flow está published (despublique antes de editar)", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } },
          "404": { "description": "Not Found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } },
          "409": { "description": "Conflict — presente numa geração mais recente do spec (15/07/2026), causa não detalhada na fonte; distinto do 403 (flow published)", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } }
        }
      },
      "delete": {
        "tags": ["flows"],
        "summary": "Remove flow",
        "description": "Soft delete — o flow passa para status `deleted`. Único caminho para remover um flow (não há hard delete no contrato público).",
        "responses": {
          "204": { "description": "No Content" },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorUnauthorizedResponse" } } } },
          "404": { "description": "Not Found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } }
        }
      }
    },
    "/flows/{id}/publish": {
      "parameters": [ { "name": "id", "in": "path", "required": true, "description": "Flow ID", "schema": { "type": "string" } } ],
      "patch": {
        "tags": ["flows"],
        "summary": "Publica flow (draft ou unpublished → published)",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/domain.Flow" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorUnauthorizedResponse" } } } },
          "404": { "description": "Not Found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } },
          "409": { "description": "Conflict", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } }
        }
      }
    },
    "/flows/{id}/unpublish": {
      "parameters": [ { "name": "id", "in": "path", "required": true, "description": "Flow ID", "schema": { "type": "string" } } ],
      "patch": {
        "tags": ["flows"],
        "summary": "Despublica flow (published → unpublished)",
        "description": "Permite voltar a editar (PUT) um flow que já foi publicado. Execuções em andamento não são afetadas.",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/domain.Flow" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorUnauthorizedResponse" } } } },
          "404": { "description": "Not Found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } },
          "409": { "description": "Conflict", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } }
        }
      }
    },
    "/flows/{id}/executions": {
      "parameters": [ { "name": "id", "in": "path", "required": true, "description": "Flow ID", "schema": { "type": "string" } } ],
      "get": {
        "tags": ["executions"],
        "summary": "Lista execuções de um flow",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/domain.Execution" } } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorUnauthorizedResponse" } } } },
          "503": { "description": "Service Unavailable", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } }
        }
      },
      "post": {
        "tags": ["executions"],
        "summary": "Inicia execução de um flow publicado",
        "description": "Persiste flow_name e account (snapshot copiado do flow; account.key e account.name vêm da introspecção do token em AUTH_URL). Chamado internamente pelo Runner ao receber POST /flows/{flow_id}/execute — não é o ponto de entrada usado pela empresa integradora (ver clickflow-runner-v1.openapi.json).",
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ExecutionDetailResponse" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorUnauthorizedResponse" } } } },
          "404": { "description": "Not Found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } }
        }
      }
    },
    "/executions/{execution_id}": {
      "parameters": [ { "name": "execution_id", "in": "path", "required": true, "description": "Execution ID", "schema": { "type": "string" } } ],
      "get": {
        "tags": ["executions"],
        "summary": "Estado da execução",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ExecutionDetailResponse" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorUnauthorizedResponse" } } } },
          "404": { "description": "Not Found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } }
        }
      }
    },
    "/executions/{execution_id}/next": {
      "parameters": [ { "name": "execution_id", "in": "path", "required": true, "description": "Execution ID", "schema": { "type": "string" } } ],
      "post": {
        "tags": ["executions"],
        "summary": "Avança para o próximo passo",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ExecutionDetailResponse" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorUnauthorizedResponse" } } } },
          "404": { "description": "Not Found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } },
          "409": { "description": "Conflict", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "Health check",
        "security": [],
        "description": "Sem autenticação. Indica se a aplicação está em pé e pronta para tráfego — valida acesso ao backend de dados configurado para esta API.",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.HealthOKResponse" } } } },
          "503": { "description": "Serviço indisponível ou dependência essencial indisponível", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/handler.ErrorResponse" } } } }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "UUID do token no header Authorization (sem Bearer). Validado por introspecção em AUTH_URL — retorna user_id e account (id numérico, key UUID e name)."
      }
    },
    "schemas": {
      "domain.Account": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "key": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "domain.FlowStatus": {
        "type": "string",
        "enum": ["draft", "published", "unpublished", "deleted"],
        "x-enum-varnames": ["FlowStatusDraft", "FlowStatusPublished", "FlowStatusUnpublished", "FlowStatusDeleted"],
        "description": "⚠️ Mudança de contrato (13/07/2026): o valor `archived` foi substituído por `unpublished` (via PATCH /flows/{id}/unpublish) e `deleted` (soft delete via DELETE /flows/{id})."
      },
      "domain.FlowStepType": {
        "type": "string",
        "enum": ["acceptance", "form", "verify", "kyc", "signature"],
        "x-enum-varnames": ["FlowStepTypeAcceptance", "FlowStepTypeForm", "FlowStepTypeVerify", "FlowStepTypeKYC", "FlowStepTypeSignature"]
      },
      "domain.FlowStep": {
        "type": "object",
        "required": ["context"],
        "properties": {
          "type": { "$ref": "#/components/schemas/domain.FlowStepType" },
          "context": { "type": "object", "additionalProperties": true, "description": "Schema livre por tipo — ver exemplos em POST /flows e docs/02-conceitos-e-modelo-de-dados.md" }
        }
      },
      "domain.Flow": {
        "type": "object",
        "properties": {
          "flow_id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "$ref": "#/components/schemas/domain.FlowStatus" },
          "steps": { "type": "array", "items": { "$ref": "#/components/schemas/domain.FlowStep" } },
          "account": { "$ref": "#/components/schemas/domain.Account" },
          "user_id": { "type": "string" },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string" }
        }
      },
      "domain.ExecutionStatus": {
        "type": "string",
        "enum": ["running", "waiting", "completed", "failed"],
        "x-enum-varnames": ["ExecutionStatusRunning", "ExecutionStatusWaiting", "ExecutionStatusCompleted", "ExecutionStatusFailed"],
        "description": "⚠️ Divergência observada: o spec publicado pelo serviço declara os valores em minúsculo (running/waiting/completed/failed), mas um payload real de produção capturado em 07/07/2026 mostrou o valor em maiúsculo (\"status\": \"RUNNING\"). Não assuma um casing sem checar a resposta real antes de fazer parsing sensível a maiúsculas/minúsculas."
      },
      "domain.Execution": {
        "type": "object",
        "description": "Formato retornado em GET /flows/{id}/executions (lista). Para uma execução individual, os endpoints retornam handler.ExecutionDetailResponse (mais completo — inclui current_step e executed_steps).",
        "properties": {
          "execution_id": { "type": "string" },
          "flow_id": { "type": "string" },
          "flow_name": { "type": "string" },
